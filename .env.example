# ===========================================
# RedAlert Shelter Bot - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Database (Required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# --- RedAlert API ---
# Get your API key from https://redalert.orielhaim.com
REDALERT_API_KEY=your-redalert-api-key

# Set to "true" to use the test server (no API key needed)
REDALERT_TEST_MODE=false

# Test server settings (only used when TEST_MODE=true)
REDALERT_TEST_TIMING=5s
REDALERT_TEST_CITIES=
REDALERT_TEST_ALERTS=missiles

# --- Bot Settings ---
BOT_PHONE_NUMBER=972501234567
LOG_LEVEL=info

# --- Initial Group Config (Optional) ---
# JSON array of groups to monitor on first boot
# After first boot, manage via !addcity / !removecity commands
# Format: [{"groupId":"120363...@g.us","groupName":"Family","cities":["תל אביב","חיפה"]}]
INITIAL_GROUPS=

# --- AI Settings (Optional) ---
# Get a free Groq API key at https://console.groq.com
# Uses Llama 3.3 70B (primary) with GPT-OSS 20B fallback
# Enables Echo AI chat via !ask, "אקו", @mention, or reply
GROQ_API_KEY=

# --- Admin Settings (Optional) ---
# Comma-separated phone numbers that can run admin commands
# If empty, all group members can use commands
ADMIN_NUMBERS=
