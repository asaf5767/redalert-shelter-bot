# ===========================================
# RedAlert Shelter Bot — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Or run: npm run setup (interactive wizard)

# --- Database (Recommended, not required) ---
# Sign up free: https://supabase.com
# Without Supabase the bot still works — session stored locally in auth_info/,
# but group configs won't persist and AI chat history won't be saved.
SUPABASE_URL=
SUPABASE_KEY=

# --- RedAlert API ---
# Get your API key from https://redalert.orielhaim.com
REDALERT_API_KEY=

# Set to "true" to use simulated alerts (no API key needed)
REDALERT_TEST_MODE=true

# Test server settings (only used when TEST_MODE=true)
REDALERT_TEST_TIMING=5s
REDALERT_TEST_CITIES=
REDALERT_TEST_ALERTS=missiles

# --- AI Features (Optional) ---
# Enables Echo AI chat: !ask, "אקו", @mention, reply, DM
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- Bot Settings ---
BOT_PHONE_NUMBER=
LOG_LEVEL=info

# --- Admin Settings (Optional) ---
# Comma-separated phone numbers that can run admin commands.
# If empty, all group members can use commands.
ADMIN_NUMBERS=

# --- Initial Group Config (Optional) ---
# JSON array of groups to monitor on first boot.
# Only needed if running without Supabase.
# Format: [{"groupId":"120363...@g.us","groupName":"Family","cities":["תל אביב","חיפה"]}]
INITIAL_GROUPS=
